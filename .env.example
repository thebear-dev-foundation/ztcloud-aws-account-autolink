# Zscaler OneAPI credentials — source these locally for the deploy script.
# Copy to .env and populate. Never commit .env.

# ZIdentity vanity domain — format: z-<orgid>.zslogin.net (NOT -admin variant)
export ZS_VANITY_DOMAIN=z-XXXXXXXX.zslogin.net

# OneAPI OAuth2 client credentials (from ZIdentity admin portal)
export ZS_CLIENT_ID=your-client-id-here
export ZS_CLIENT_SECRET=your-client-secret-here

# AWS region where the reconciler Lambda is deployed (Audit account region)
export AWS_REGION=us-east-1
